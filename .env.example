# ============================================================
# Backbone & MBH Monitoring - Configuration Environnement
# Copier ce fichier en .env et adapter les valeurs
# ============================================================

# --- Base de donnees PostgreSQL ---
POSTGRES_DB=supervision
POSTGRES_USER=supervision
POSTGRES_PASSWORD=ChangeMeSecurePassword123!
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- API Flask ---
FLASK_ENV=production
FLASK_SECRET_KEY=change-this-secret-key-in-production
API_HOST=0.0.0.0
API_PORT=5000

# --- Grafana ---
GRAFANA_PASSWORD=admin123

# --- SNMP Global ---
SNMP_DEFAULT_VERSION=2c
# SNMP Communities - Backbone (10.200.0.0/16) et MBH (10.40, 10.42, 10.44)
SNMP_BACKBONE_COMMUNITY=mpbn
SNMP_MBH_COMMUNITY=mobilis-read-only
SNMP_TIMEOUT=5
SNMP_RETRIE

# --- SNMP v3 (si utilise) ---
SNMP_V3_USERNAME=snmpuser
SNMP_V3_AUTH_PROTOCOL=SHA
SNMP_V3_AUTH_PASSWORD=authpassword
SNMP_V3_PRIV_PROTOCOL=AES
SNMP_V3_PRIV_PASSWORD=privpassword

# --- Polling intervals (secondes) ---
POLL_INTERVAL_INTERFACES=60
POLL_INTERVAL_BGP=120
POLL_INTERVAL_MPLS=120
POLL_INTERVAL_MBH=60
POLL_INTERVAL_TOPOLOGY=300

# --- Alertes seuils ---
ALERT_INTERFACE_BW_THRESHOLD=80
ALERT_BGP_DOWN=true
ALERT_MPLS_LSP_DOWN=true
ALERT_MBH_RSSI_THRESHOLD=-85
ALERT_MBH_BER_THRESHOLD=1e-6

# --- Notification (Email SMTP) ---
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASSWORD=smtppassword
SMTP_FROM=supervision@example.com
SMTP_TO=admin@example.com

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=/var/log/supervision/app.log

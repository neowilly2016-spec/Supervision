    {
      "datasource": {"type": "postgres", "uid": "supervision_pg"},
      "fieldConfig": {"defaults": {}},
      "gridPos": {"h": 14, "w": 24, "x": 0, "y": 4},
      "id": 5,
      "title": "IP Prefixes with VLAN & VRF Enrichment",
      "type": "table",
      "targets": [{
        "datasource": {"type": "postgres", "uid": "supervision_pg"},
        "rawSql": "SELECT p.prefix, p.prefix_length, p.status, p.is_pool, p.utilization, vl.vid, vl.name AS vlan_name, vl.site, vr.name AS vrf_name, vr.rd FROM ip_prefixes p LEFT JOIN vlans vl ON p.vlan_id = vl.id LEFT JOIN vrfs vr ON p.vrf_id = vr.id WHERE p.status = 'active' ORDER BY p.prefix;",
        "refId": "A",
        "format": "table"
      }]
    },
    {
      "datasource": {"type": "postgres", "uid": "supervision_pg"},
      "fieldConfig": {"defaults": {}},
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 18},
      "id": 6,
      "title": "Prefixes by VLAN (Top 10)",
      "type": "bargauge",
      "targets": [{
        "datasource": {"type": "postgres", "uid": "supervision_pg"},
        "rawSql": "SELECT vl.name AS metric, COUNT(p.id) AS value FROM ip_prefixes p JOIN vlans vl ON p.vlan_id = vl.id WHERE p.status = 'active' GROUP BY vl.name ORDER BY value DESC LIMIT 10;",
        "refId": "A",
        "format": "table"
      }],
      "options": {"orientation": "horizontal", "displayMode": "gradient"}
    }

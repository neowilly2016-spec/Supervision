        }
      ]
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "supervision_pg"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Total VRFs",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "supervision_pg" },
          "rawSql": "SELECT COUNT(*) AS value FROM vrfs;",
